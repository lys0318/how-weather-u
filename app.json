{
  "expo": {
    "name": "하우웨더유",
    "slug": "howweateryou",
    "scheme": "howweateryou",
    "version": "1.0.21",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F3ECDF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.howweatheryou.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "현재 날씨를 기반으로 맞춤 메시지를 보내드리기 위해 위치 정보가 필요합니다.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "백그라운드에서도 날씨 기반 메시지를 보내드리기 위해 위치 정보가 필요합니다.",
        "NSUserNotificationsUsageDescription": "날씨에 맞는 감성 메시지를 주기적으로 알려드리기 위해 알림 권한이 필요합니다.",
        "UIBackgroundModes": [
          "fetch",
          "remote-notification",
          "fetch",
          "remote-notification"
        ]
      }
    },
    "android": {
      "package": "com.howweatheryou.app",
      "versionCode": 23,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#7A6796"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": false,
          "data": [
            {
              "scheme": "howweateryou"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.WAKE_LOCK",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.WAKE_LOCK"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "백그라운드에서도 날씨 기반 메시지를 보내드리기 위해 위치 정보가 필요합니다."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0f0f0f",
          "sounds": []
        }
      ],
      [
        "expo-background-fetch",
        {}
      ],
      "expo-web-browser",
      "@sentry/react-native",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-8051681065734198~5789260751"
        }
      ],
      "expo-localization"
    ],
    "extra": {
      "eas": {
        "projectId": "d07d8b4f-4c32-4381-9a5a-c22473730d15"
      }
    },
    "owner": "lys03"
  }
}
